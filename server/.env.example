# 微信云托管 MySQL 环境变量（云托管自动注入，本地开发手动填）
#
# 云托管部署时不需要 .env 文件，环境变量由平台注入。
# 本地开发时：cp .env.example .env，然后填值。

MYSQL_ADDRESS=localhost:3306
MYSQL_USERNAME=root
MYSQL_PASSWORD=
MYSQL_DATABASE=lebron

# Node 服务端口（云托管要求 80）
PORT=80

# DeepSeek API（可选，不填则 /api/llm/enhance 返回 503）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
