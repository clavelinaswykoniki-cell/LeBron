/* pages/about/about.wxss */

.page {
  min-height: 100vh;
  background: #1a0a2e;
  padding: 32rpx 24rpx 64rpx;
  box-sizing: border-box;
  color: #ffffff;
}

.section {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 215, 0, 0.18);
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.3);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffd700;
  margin-bottom: 24rpx;
  letter-spacing: 2rpx;
}

/* ---- rank-section ---- */
.rank-section {
  text-align: center;
}

.rank-title {
  font-size: 56rpx;
  font-weight: 700;
  color: #ffd700;
  letter-spacing: 4rpx;
  margin-bottom: 24rpx;
  text-shadow: 0 2rpx 12rpx rgba(255, 215, 0, 0.4);
}

.rank-progress {
  margin: 0 auto 24rpx;
  max-width: 560rpx;
}

.rank-bar {
  height: 16rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 8rpx;
  overflow: hidden;
}

.rank-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #ffd700, #ffae00);
  border-radius: 8rpx;
  transition: width 0.4s ease;
}

.rank-progress-text {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.65);
}

.rank-stat {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
}

/* ---- badges-section ---- */
.badges-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.badge-item {
  flex: 0 0 calc(50% - 8rpx);
  box-sizing: border-box;
  border-radius: 16rpx;
  padding: 24rpx 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  background: rgba(255, 255, 255, 0.04);
  text-align: center;
}

.badge-item.unlocked {
  background: linear-gradient(135deg, rgba(255, 215, 0, 0.18), rgba(255, 165, 0, 0.12));
  border-color: rgba(255, 215, 0, 0.6);
  box-shadow: 0 0 12rpx rgba(255, 215, 0, 0.25);
}

.badge-item.locked {
  opacity: 0.4;
  filter: grayscale(0.8);
}

.badge-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffd700;
  margin-bottom: 8rpx;
}

.badge-item.locked .badge-name {
  color: rgba(255, 255, 255, 0.7);
}

.badge-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.4;
}

/* ---- info-section ---- */
.info-row {
  display: flex;
  justify-content: space-between;
  padding: 14rpx 0;
  border-bottom: 1rpx dashed rgba(255, 255, 255, 0.1);
  font-size: 26rpx;
}

.info-row:last-of-type {
  border-bottom: none;
}

.info-key {
  color: rgba(255, 255, 255, 0.7);
}

.info-val {
  color: #ffffff;
  font-weight: 500;
}

.tribute {
  margin-top: 28rpx;
  padding: 20rpx;
  text-align: center;
  font-size: 26rpx;
  color: #ffd700;
  background: rgba(255, 215, 0, 0.08);
  border-radius: 12rpx;
  letter-spacing: 1rpx;
}

.disclaimer {
  margin-top: 20rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.55);
  line-height: 1.6;
  text-align: center;
}

.back-btn {
  margin-top: 36rpx;
  background: linear-gradient(90deg, #ffd700, #ffae00);
  color: #1a0a2e;
  font-weight: 600;
  font-size: 30rpx;
  border-radius: 48rpx;
  border: none;
}

.back-btn::after {
  border: none;
}
