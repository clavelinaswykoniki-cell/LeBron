<view class="onboarding-page">
  <view class="dots">
    <view wx:for="{{steps}}" wx:key="id" class="dot {{index === step ? 'active' : ''}}"></view>
  </view>

  <!-- 教学步：emoji + title + desc -->
  <view class="card" wx:if="{{current.type === 'intro'}}">
    <text class="emoji">{{current.emoji}}</text>
    <view class="title">{{current.title}}</view>
    <view class="desc">{{current.desc}}</view>
  </view>

  <!-- profile 步：选头像 + 填昵称 -->
  <view class="card profile-card" wx:else>
    <view class="profile-title">{{current.title}}</view>
    <view class="profile-desc">{{current.desc}}</view>

    <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image wx:if="{{avatarUrl}}" class="avatar-img" src="{{avatarUrl}}" mode="aspectFill"/>
      <view wx:else class="avatar-placeholder">
        <text class="avatar-icon">📷</text>
        <text class="avatar-hint">点击选头像</text>
      </view>
    </button>

    <input
      class="nickname-input"
      type="nickname"
      placeholder="输入昵称"
      value="{{nickname}}"
      bindblur="onNicknameInput"
      bindinput="onNicknameInput"
      bindchange="onNicknameInput"
      maxlength="20"
    />
  </view>

  <view class="actions">
    <button class="primary" bindtap="next">{{current.cta}}</button>
    <button class="ghost" bindtap="skip">跳过</button>
  </view>
  <view class="version">v2.6 · 练手项目</view>
</view>
