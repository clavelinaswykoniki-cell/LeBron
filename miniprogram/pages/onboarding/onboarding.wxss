/* F9 Onboarding · 紫金主题 */

.onboarding-page {
  min-height: 100vh;
  width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 80rpx 60rpx 60rpx;
  background: linear-gradient(160deg, #1a0a2e 0%, #2d1245 45%, #3a1860 100%);
  position: relative;
  overflow: hidden;
}

.onboarding-page::before {
  content: "";
  position: absolute;
  top: -200rpx;
  right: -200rpx;
  width: 500rpx;
  height: 500rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 215, 0, 0.12) 0%, transparent 70%);
  pointer-events: none;
}

.onboarding-page::after {
  content: "";
  position: absolute;
  bottom: -250rpx;
  left: -150rpx;
  width: 600rpx;
  height: 600rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(138, 79, 255, 0.18) 0%, transparent 70%);
  pointer-events: none;
}

/* 顶部 dots indicator */
.dots {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 16rpx;
  margin-top: 20rpx;
  z-index: 2;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.22);
  transition: all 0.3s ease;
}

.dot.active {
  width: 48rpx;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #ffd700 0%, #ffae00 100%);
  box-shadow: 0 0 16rpx rgba(255, 215, 0, 0.55);
}

/* 居中卡片 */
.card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  width: 100%;
  padding: 60rpx 30rpx;
  z-index: 2;
}

.emoji {
  display: block;
  font-size: 80rpx;
  line-height: 1;
  margin-bottom: 50rpx;
  text-align: center;
  animation: breathe 2.4s ease-in-out infinite;
  filter: drop-shadow(0 0 24rpx rgba(255, 215, 0, 0.45));
}

@keyframes breathe {
  0%, 100% {
    transform: scale(1);
    filter: drop-shadow(0 0 16rpx rgba(255, 215, 0, 0.35));
  }
  50% {
    transform: scale(1.05);
    filter: drop-shadow(0 0 32rpx rgba(255, 215, 0, 0.65));
  }
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.4;
  margin-bottom: 32rpx;
  background: linear-gradient(135deg, #ffd700 0%, #ffae00 60%, #ff8c00 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  letter-spacing: 1rpx;
}

.desc {
  font-size: 28rpx;
  line-height: 1.7;
  color: #d6c5f5;
  white-space: pre-line;
  max-width: 560rpx;
  opacity: 0.9;
}

/* 按钮区 */
.actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  z-index: 2;
}

.actions button {
  width: 100%;
  max-width: 560rpx;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  margin: 0;
  padding: 0;
}

.actions button::after {
  border: none;
}

.actions .primary {
  background: linear-gradient(135deg, #ffd700 0%, #ffae00 100%);
  color: #2d1245;
  box-shadow: 0 12rpx 32rpx rgba(255, 174, 0, 0.4),
              0 0 0 1rpx rgba(255, 215, 0, 0.5) inset;
}

.actions .primary:active {
  transform: scale(0.97);
  box-shadow: 0 6rpx 16rpx rgba(255, 174, 0, 0.5);
}

.actions .ghost {
  background: transparent;
  color: #b8a3e0;
  border: 2rpx solid rgba(184, 163, 224, 0.4);
}

.actions .ghost:active {
  background: rgba(255, 255, 255, 0.06);
}

/* 版本号 */
.version {
  margin-top: 30rpx;
  font-size: 22rpx;
  color: rgba(184, 163, 224, 0.45);
  letter-spacing: 1rpx;
  z-index: 2;
}
