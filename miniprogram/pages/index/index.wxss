.page {
  padding-bottom: 64rpx;
}

.hero {
  margin-bottom: 28rpx;
}

.eyebrow {
  color: #fbbf24;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.title {
  margin-top: 8rpx;
  color: #f8fafc;
  font-size: 52rpx;
  font-weight: 900;
  line-height: 1.1;
}

.subtitle {
  margin-top: 14rpx;
  color: #94a3b8;
  font-size: 26rpx;
  line-height: 1.5;
}

.panel {
  padding: 24rpx;
}

.query-input {
  width: 100%;
  min-height: 150rpx;
  box-sizing: border-box;
  padding: 22rpx;
  border-radius: 16rpx;
  background: #020617;
  color: #f8fafc;
  border: 1rpx solid rgba(148, 163, 184, 0.28);
  font-size: 28rpx;
  line-height: 1.5;
}

.actions {
  display: flex;
  gap: 18rpx;
  margin-top: 22rpx;
}

.primary-btn,
.ghost-btn,
.copy-btn {
  margin: 0;
  border-radius: 14rpx;
  font-weight: 800;
}

.primary-btn {
  flex: 1;
  background: #fbbf24;
  color: #111827;
}

.ghost-btn {
  width: 210rpx;
  background: #1f2937;
  color: #f8fafc;
  border: 1rpx solid rgba(148, 163, 184, 0.28);
}

.quick {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin: 24rpx 0;
}

.quick-chip {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(251, 191, 36, 0.12);
  color: #fcd34d;
  font-size: 24rpx;
  border: 1rpx solid rgba(251, 191, 36, 0.24);
}

.results {
  margin-top: 20rpx;
}

.result-count {
  margin-bottom: 16rpx;
  color: #94a3b8;
  font-size: 24rpx;
}

.result-card {
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.category {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #7c2d12;
  color: #fed7aa;
  font-size: 22rpx;
  font-weight: 800;
}

.alias {
  color: #94a3b8;
  font-size: 22rpx;
}

.claim {
  margin-top: 20rpx;
  color: #f8fafc;
  font-size: 32rpx;
  line-height: 1.45;
  font-weight: 900;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.tag {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(59, 130, 246, 0.12);
  color: #bfdbfe;
  font-size: 21rpx;
  border: 1rpx solid rgba(96, 165, 250, 0.18);
}

.section {
  margin-top: 22rpx;
  padding: 20rpx;
  background: #020617;
  border-radius: 16rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.18);
}

.section-title {
  color: #fbbf24;
  font-size: 24rpx;
  font-weight: 900;
  margin-bottom: 12rpx;
}

.reply,
.one-liner {
  color: #e5e7eb;
  font-size: 27rpx;
  line-height: 1.6;
}

.one-liner {
  font-weight: 900;
  color: #f8fafc;
}

.copy-btn {
  margin-top: 16rpx;
  width: 160rpx;
  height: 60rpx;
  line-height: 60rpx;
  background: #1f2937;
  color: #f8fafc;
  font-size: 24rpx;
}

.logic-grid {
  margin-top: 20rpx;
  display: grid;
  gap: 14rpx;
}

.logic-item {
  padding: 18rpx;
  border-radius: 14rpx;
  background: rgba(15, 23, 42, 0.92);
  border: 1rpx solid rgba(148, 163, 184, 0.16);
}

.logic-label {
  color: #93c5fd;
  font-size: 22rpx;
  font-weight: 800;
  margin-bottom: 8rpx;
}

.logic-text {
  color: #cbd5e1;
  font-size: 24rpx;
  line-height: 1.55;
}

.facts {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: rgba(251, 191, 36, 0.08);
  border: 1rpx solid rgba(251, 191, 36, 0.18);
}

.facts-title {
  color: #fbbf24;
  font-size: 23rpx;
  font-weight: 900;
  margin-bottom: 8rpx;
}

.fact-row {
  color: #fde68a;
  font-size: 23rpx;
  line-height: 1.55;
}
