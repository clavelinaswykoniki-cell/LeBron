/* ============================================
 * 首页样式 · 极简紫金 · v2.6
 * 设计原则：留白 > 色块；色块仅在 CTA / brand
 * 配色：#552583 主紫  /  #FDB927 主金
 * ============================================ */

page {
  --brand-purple: #552583;
  --brand-purple-soft: rgba(85, 37, 131, 0.08);
  --brand-purple-line: rgba(85, 37, 131, 0.18);
  --brand-gold: #fdb927;
  --brand-gold-soft: rgba(253, 185, 39, 0.12);
  --ink-1: #1a1a1f;
  --ink-2: #4a4a52;
  --ink-3: #8e8e95;
  --ink-4: #c7c7cd;
  --bg-page: #fafafa;
  --bg-card: #ffffff;
  --line: rgba(0, 0, 0, 0.06);

  /* 覆盖 TDesign primary 用作 CTA */
  --td-brand-color: #552583;
  --td-brand-color-1: rgba(85, 37, 131, 0.06);
  --td-brand-color-2: rgba(85, 37, 131, 0.12);
  --td-brand-color-3: rgba(85, 37, 131, 0.2);
  --td-brand-color-7: #4a1f74;
  --td-brand-color-8: #552583;

  background: var(--bg-page);
  color: var(--ink-1);
}

.page {
  min-height: 100vh;
  padding: 24rpx 32rpx 64rpx;
  box-sizing: border-box;
}

/* === Top bar ============================== */
.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
}

.brand {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.brand-mark {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  background: var(--brand-purple);
  color: var(--brand-gold);
  font-size: 28rpx;
  font-weight: 900;
  letter-spacing: -1rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: -apple-system, "SF Pro Display", sans-serif;
}

.brand-name {
  color: var(--ink-1);
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.rank-chip {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  height: 56rpx;
  padding: 0 18rpx;
  border-radius: 28rpx;
  background: var(--brand-purple-soft);
  color: var(--brand-purple);
  font-size: 22rpx;
  font-weight: 600;
}

.rank-chip-name {
  line-height: 1;
}

.rank-chip-arrow {
  color: var(--brand-purple);
  font-size: 28rpx;
  line-height: 1;
  opacity: 0.5;
  margin-left: 4rpx;
}

.rank-bronze   { background: rgba(180, 120, 60, 0.1); color: #8a5a2a; }
.rank-silver   { background: rgba(120, 130, 140, 0.1); color: #5a6470; }
.rank-gold     { background: rgba(253, 185, 39, 0.15); color: #a07410; }
.rank-diamond  { background: rgba(85, 37, 131, 0.1); color: #552583; }
.rank-king     {
  background: linear-gradient(135deg, rgba(85, 37, 131, 0.15), rgba(253, 185, 39, 0.18));
  color: #552583;
}

/* === Composer (核心输入区) ================ */
.composer {
  margin-top: 56rpx;
}

.composer-hint {
  color: var(--ink-3);
  font-size: 26rpx;
  font-weight: 500;
  margin-bottom: 18rpx;
  letter-spacing: 0.5rpx;
}

.composer-shell {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 32rpx 28rpx;
  box-shadow:
    0 1rpx 0 var(--line),
    0 8rpx 32rpx rgba(85, 37, 131, 0.05);
}

.composer-input {
  width: 100%;
  min-height: 180rpx;
  color: var(--ink-1);
  font-size: 36rpx;
  font-weight: 500;
  line-height: 1.5;
  box-sizing: border-box;
}

.composer-placeholder {
  color: var(--ink-4);
  font-weight: 400;
}

.composer-actions {
  display: flex;
  align-items: stretch;
  gap: 16rpx;
  margin-top: 20rpx;
}

.cta-primary {
  flex: 1;
  margin: 0;
}

.cta-primary-text {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.cta-random {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  background: var(--bg-card);
  border: 1rpx solid var(--brand-purple-line);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.15s ease, background 0.15s ease;
}

.cta-random:active {
  transform: scale(0.92);
  background: var(--brand-purple-soft);
}

/* === Mood chips ============================ */
.mood-row {
  display: flex;
  gap: 12rpx;
  margin-top: 36rpx;
  padding: 0 4rpx;
}

.mood-chip {
  flex: 1;
  height: 64rpx;
  border-radius: 32rpx;
  background: transparent;
  border: 1rpx solid var(--line);
  color: var(--ink-2);
  font-size: 24rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.18s ease;
}

.mood-chip-active {
  background: var(--ink-1);
  border-color: var(--ink-1);
  color: #ffffff;
  font-weight: 600;
}

/* === Hot block ============================= */
.hot-block {
  margin-top: 56rpx;
}

.hot-label {
  color: var(--ink-3);
  font-size: 22rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
  margin-bottom: 16rpx;
  text-transform: uppercase;
}

.hot-scroll {
  width: 100%;
  white-space: nowrap;
}

.hot-chip {
  display: inline-flex;
  align-items: center;
  height: 64rpx;
  padding: 0 24rpx;
  margin-right: 12rpx;
  border-radius: 32rpx;
  background: var(--bg-card);
  border: 1rpx solid var(--line);
  color: var(--ink-1);
  font-size: 24rpx;
  font-weight: 500;
  transition: background 0.15s ease;
}

.hot-chip:active {
  background: var(--brand-purple-soft);
  border-color: var(--brand-purple-line);
  color: var(--brand-purple);
}

/* === Nav row =============================== */
.nav-row {
  margin-top: 80rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8rpx;
  padding: 24rpx 16rpx;
  background: var(--bg-card);
  border-radius: 20rpx;
  border: 1rpx solid var(--line);
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 12rpx 0;
  transition: opacity 0.15s ease;
}

.nav-item:active {
  opacity: 0.55;
}

.nav-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: var(--brand-purple-soft);
  color: var(--brand-purple);
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-text {
  color: var(--ink-2);
  font-size: 22rpx;
  font-weight: 500;
}

/* === Footer ================================ */
.footer-note {
  margin-top: 48rpx;
  text-align: center;
  font-size: 20rpx;
  color: var(--ink-4);
}

.footer-text {
  color: var(--ink-4);
}

.footer-link {
  color: var(--ink-3);
}
