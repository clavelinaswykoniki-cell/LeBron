.page {
  padding-bottom: 64rpx;
}

.hero {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 22rpx;
  margin-bottom: 24rpx;
}

.eyebrow {
  color: #fbbf24;
  font-size: 21rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}

.title {
  margin-top: 8rpx;
  color: #f8fafc;
  font-size: 50rpx;
  font-weight: 900;
  line-height: 1.08;
}

.subtitle {
  margin-top: 14rpx;
  color: #a7b0c0;
  font-size: 25rpx;
  line-height: 1.5;
}

.arsenal {
  flex: 0 0 176rpx;
  padding: 18rpx 16rpx;
  box-sizing: border-box;
  border-radius: 16rpx;
  background: #7f1d1d;
  border: 1rpx solid rgba(252, 165, 165, 0.36);
  text-align: center;
}

.arsenal-num {
  color: #fef2f2;
  font-size: 48rpx;
  line-height: 1;
  font-weight: 900;
}

.arsenal-label {
  margin-top: 8rpx;
  color: #fecaca;
  font-size: 23rpx;
  font-weight: 800;
}

.arsenal-sub {
  margin-top: 6rpx;
  color: #fed7aa;
  font-size: 20rpx;
}

.panel {
  padding: 22rpx;
  border-radius: 18rpx;
  background: #111827;
  border: 1rpx solid rgba(148, 163, 184, 0.24);
  box-shadow: 0 18rpx 48rpx rgba(0, 0, 0, 0.26);
}

.panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.panel-title {
  color: #f8fafc;
  font-size: 28rpx;
  font-weight: 900;
}

.panel-note {
  color: #94a3b8;
  font-size: 22rpx;
}

.query-input {
  width: 100%;
  min-height: 148rpx;
  box-sizing: border-box;
  padding: 22rpx;
  border-radius: 14rpx;
  background: #020617;
  color: #f8fafc;
  border: 1rpx solid rgba(148, 163, 184, 0.3);
  font-size: 28rpx;
  line-height: 1.55;
}

.actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.primary-btn,
.ghost-btn,
.copy-btn,
.copy-all-btn,
.copy-card-btn,
.enhance-btn {
  margin: 0;
  border-radius: 12rpx;
  font-weight: 900;
}

.primary-btn {
  flex: 1;
  background: #fbbf24;
  color: #111827;
}

.ghost-btn {
  width: 204rpx;
  background: #263244;
  color: #f8fafc;
  border: 1rpx solid rgba(148, 163, 184, 0.28);
}

.quick-section {
  margin-top: 24rpx;
}

.tool-title {
  color: #f8fafc;
  font-size: 25rpx;
  font-weight: 900;
  margin-bottom: 14rpx;
}

.quick {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.quick-chip {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(251, 191, 36, 0.12);
  color: #fcd34d;
  font-size: 24rpx;
  border: 1rpx solid rgba(251, 191, 36, 0.24);
}

.category-scroll {
  margin-top: 24rpx;
  white-space: nowrap;
  width: 100%;
}

.category-chip {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  margin-right: 12rpx;
  padding: 12rpx 16rpx;
  border-radius: 999rpx;
  background: #182235;
  color: #cbd5e1;
  font-size: 23rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.22);
}

.category-chip.active {
  background: #fbbf24;
  color: #111827;
  border-color: #fbbf24;
  font-weight: 900;
}

.category-count {
  min-width: 32rpx;
  padding: 2rpx 8rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.45);
  color: #e5e7eb;
  font-size: 20rpx;
  text-align: center;
}

.category-chip.active .category-count {
  background: rgba(17, 24, 39, 0.16);
  color: #111827;
}

.toolbar {
  position: sticky;
  top: 0;
  z-index: 5;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin: 24rpx 0 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: rgba(2, 6, 23, 0.96);
  border: 1rpx solid rgba(148, 163, 184, 0.24);
}

.toolbar-title {
  color: #f8fafc;
  font-size: 25rpx;
  font-weight: 900;
}

.toolbar-sub {
  margin-top: 4rpx;
  color: #94a3b8;
  font-size: 21rpx;
}

.copy-all-btn {
  width: 176rpx;
  height: 62rpx;
  line-height: 62rpx;
  background: #dc2626;
  color: #fff7ed;
  font-size: 24rpx;
}

.results {
  margin-top: 16rpx;
}

.result-card {
  position: relative;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border-radius: 18rpx;
  background: #101827;
  border: 1rpx solid rgba(148, 163, 184, 0.22);
  box-shadow: 0 18rpx 48rpx rgba(0, 0, 0, 0.24);
}

.result-card::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  width: 8rpx;
  height: 100%;
  border-radius: 18rpx 0 0 18rpx;
  background: #dc2626;
}

.meta-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.category {
  display: inline-block;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #7c2d12;
  color: #fed7aa;
  font-size: 22rpx;
  font-weight: 900;
}

.alias {
  display: inline-block;
  margin-left: 10rpx;
  color: #94a3b8;
  font-size: 22rpx;
}

.copy-card-btn {
  width: 164rpx;
  height: 56rpx;
  line-height: 56rpx;
  background: #1f2937;
  color: #f8fafc;
  font-size: 22rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.25);
}

.card-actions {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  flex: 0 0 164rpx;
}

.enhance-btn {
  width: 164rpx;
  height: 56rpx;
  line-height: 56rpx;
  background: #fbbf24;
  color: #111827;
  font-size: 22rpx;
}

.enhance-btn[disabled] {
  background: #475569;
  color: #cbd5e1;
}

.claim {
  margin-top: 20rpx;
  color: #f8fafc;
  font-size: 31rpx;
  line-height: 1.45;
  font-weight: 900;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.tag {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(59, 130, 246, 0.12);
  color: #bfdbfe;
  font-size: 21rpx;
  border: 1rpx solid rgba(96, 165, 250, 0.18);
}

.section {
  margin-top: 20rpx;
  padding: 18rpx;
  background: #020617;
  border-radius: 14rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.18);
}

.section-title {
  color: #fbbf24;
  font-size: 24rpx;
  font-weight: 900;
  margin-bottom: 12rpx;
}

.reply,
.one-liner {
  color: #e5e7eb;
  font-size: 27rpx;
  line-height: 1.6;
}

.one-liner {
  color: #f8fafc;
  font-weight: 900;
}

.copy-btn {
  margin-top: 16rpx;
  width: 144rpx;
  height: 56rpx;
  line-height: 56rpx;
  background: #263244;
  color: #f8fafc;
  font-size: 23rpx;
}

.logic-grid {
  margin-top: 20rpx;
  display: grid;
  gap: 14rpx;
}

.logic-item {
  padding: 18rpx;
  border-radius: 14rpx;
  background: rgba(15, 23, 42, 0.92);
  border: 1rpx solid rgba(148, 163, 184, 0.16);
}

.logic-label {
  color: #93c5fd;
  font-size: 22rpx;
  font-weight: 900;
  margin-bottom: 8rpx;
}

.logic-text {
  color: #cbd5e1;
  font-size: 24rpx;
  line-height: 1.55;
}

.facts {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: rgba(251, 191, 36, 0.08);
  border: 1rpx solid rgba(251, 191, 36, 0.18);
}

.facts-title {
  color: #fbbf24;
  font-size: 23rpx;
  font-weight: 900;
  margin-bottom: 8rpx;
}

.fact-row {
  color: #fde68a;
  font-size: 23rpx;
  line-height: 1.55;
}

.empty-state {
  margin-top: 28rpx;
  padding: 32rpx;
  border-radius: 18rpx;
  background: rgba(15, 23, 42, 0.8);
  border: 1rpx solid rgba(148, 163, 184, 0.18);
  text-align: center;
}

.empty-title {
  color: #f8fafc;
  font-size: 28rpx;
  font-weight: 900;
}

.empty-sub {
  margin-top: 10rpx;
  color: #94a3b8;
  font-size: 24rpx;
}
