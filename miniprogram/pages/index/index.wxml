<view class="safe-area page">
  <view class="hero">
    <view>
      <view class="eyebrow">COMMENT WAR ROOM</view>
      <view class="title">詹黑逻辑拆解器</view>
      <view class="subtitle">输入黑点、黑称或球星对比，直接拉出可复制弹药。</view>
    </view>
    <view class="arsenal">
      <view class="arsenal-num">{{arsenalStats.cards}}</view>
      <view class="arsenal-label">反驳卡</view>
      <view class="arsenal-sub">{{arsenalStats.aliases}} 个短词命中</view>
    </view>
  </view>

  <view class="panel">
    <view class="panel-head">
      <view class="panel-title">作战输入</view>
      <view class="panel-note">短词、黑称、整句都能搜</view>
    </view>
    <textarea
      class="query-input"
      placeholder="例如：8分 / 米奇冠军 / 科比五冠 / Excel球王 / 老张跑路"
      value="{{query}}"
      bindinput="onInput"
      maxlength="120"
      auto-height
    />
    <view class="actions">
      <button class="primary-btn" bindtap="onGenerate">生成反驳</button>
      <button class="ghost-btn" bindtap="onRandom">随机一条</button>
    </view>
  </view>

  <view class="quick-section">
    <view class="tool-title">高频黑点</view>
    <view class="quick">
    <view
      wx:for="{{quickInputs}}"
      wx:key="*this"
      class="quick-chip"
      data-value="{{item}}"
      bindtap="onQuickTap"
    >{{item}}</view>
    </view>
  </view>

  <scroll-view class="category-scroll" scroll-x enable-flex>
    <view
      wx:for="{{categoryFilters}}"
      wx:key="name"
      class="category-chip {{activeCategory === item.name ? 'active' : ''}}"
      data-category="{{item.name}}"
      bindtap="onCategoryTap"
    >
      <text>{{item.name}}</text>
      <text class="category-count">{{item.count}}</text>
    </view>
  </scroll-view>

  <view wx:if="{{results.length}}" class="toolbar">
    <view>
      <view class="toolbar-title">命中 {{results.length}} 张弹药卡</view>
      <view class="toolbar-sub">当前分类：{{activeCategory}}</view>
    </view>
    <button class="copy-all-btn" bindtap="copyAll">复制全部</button>
  </view>

  <view wx:if="{{results.length}}" class="results">
    <view wx:for="{{results}}" wx:key="resultKey" class="result-card">
      <view class="meta-row">
        <view>
          <text class="category">{{item.category}}</text>
          <text class="alias">命中：{{item.alias}}</text>
        </view>
        <button class="copy-card-btn" data-index="{{index}}" bindtap="copyCard">复制整张</button>
      </view>
      <view class="claim">{{item.card.claim}}</view>

      <view wx:if="{{item.card.tags.length}}" class="tags">
        <text wx:for="{{item.card.tags}}" wx:key="*this" class="tag">{{item}}</text>
      </view>

      <view class="section">
        <view class="section-title">评论区短刀</view>
        <view class="reply">{{item.card.short_reply}}</view>
        <button class="copy-btn" data-text="{{item.card.short_reply}}" bindtap="copyText">复制</button>
      </view>

      <view class="section">
        <view class="section-title">长线拆解</view>
        <view class="reply">{{item.card.long_reply}}</view>
        <button class="copy-btn" data-text="{{item.card.long_reply}}" bindtap="copyText">复制</button>
      </view>

      <view class="section compact">
        <view class="section-title">一句话封口</view>
        <view class="one-liner">{{item.card.one_liner}}</view>
        <button class="copy-btn" data-text="{{item.card.one_liner}}" bindtap="copyText">复制</button>
      </view>

      <view class="section">
        <view class="section-title">口播弹药</view>
        <view class="reply">{{item.card.video_script}}</view>
        <button class="copy-btn" data-text="{{item.card.video_script}}" bindtap="copyText">复制</button>
      </view>

      <view class="logic-grid">
        <view class="logic-item">
          <view class="logic-label">可承认事实</view>
          <view class="logic-text">{{item.card.valid_part}}</view>
        </view>
        <view class="logic-item">
          <view class="logic-label">逻辑漏洞</view>
          <view class="logic-text">{{item.card.logic_flaw}}</view>
        </view>
        <view class="logic-item wide">
          <view class="logic-label">同标准对比</view>
          <view class="logic-text">{{item.card.comparison}}</view>
        </view>
      </view>

      <view wx:if="{{item.card.facts.length}}" class="facts">
        <view class="facts-title">事实点</view>
        <view wx:for="{{item.card.facts}}" wx:key="*this" class="fact-row">• {{item}}</view>
      </view>
    </view>
  </view>

  <view wx:else class="empty-state">
    <view class="empty-title">没有命中当前分类</view>
    <view class="empty-sub">切回“全部”，或换一个黑点继续搜。</view>
  </view>
</view>
