<view class="page">

  <!-- 顶栏：app 标识 + 段位徽章 -->
  <view class="topbar">
    <view class="brand">
      <view class="brand-mark">23</view>
      <text class="brand-name">逻辑拆解器</text>
    </view>
    <view
      wx:if="{{rank}}"
      class="rank-chip rank-{{rank.rank.id}}"
      data-url="/pages/about/about"
      bindtap="onMenuTap"
    >
      <text class="rank-chip-name">{{rank.rank.name}}</text>
      <text class="rank-chip-arrow">›</text>
    </view>
  </view>

  <!-- 主输入区（第一屏视觉焦点） -->
  <view class="composer">
    <view class="composer-hint">把对方那句话粘进来</view>
    <view class="composer-shell">
      <textarea
        class="composer-input"
        placeholder="例如：他8分释兵权"
        placeholder-class="composer-placeholder"
        value="{{query}}"
        bindinput="onInput"
        maxlength="120"
        auto-height
        cursor-color="#552583"
      />
    </view>

    <view class="composer-actions">
      <t-button
        class="cta-primary"
        theme="primary"
        block
        shape="round"
        bindtap="onGenerate"
      >
        <text class="cta-primary-text">生成反驳</text>
      </t-button>
      <view class="cta-random" bindtap="onRandom">
        <t-icon name="refresh" size="32rpx" color="#552583" />
      </view>
    </view>

    <!-- 「问 AI」入口：紧贴 CTA 下方，作为补充手段（多轮聊天） -->
    <view class="mood-row" style="margin-top: 16rpx;">
      <view class="mood-chip mood-chip-active" bindtap="onChatTap">
        <text>问 AI · 多轮聊</text>
      </view>
    </view>
  </view>

  <!-- 风格切换（mood）：轻量 chip 行，保留 handler -->
  <view class="mood-row">
    <view
      wx:for="{{moodTabs}}"
      wx:key="id"
      class="mood-chip {{activeMood === item.id ? 'mood-chip-active' : ''}}"
      data-mood="{{item.id}}"
      bindtap="onMoodTap"
    >{{item.name}}</view>
  </view>

  <!-- 热梗快捷入口：水平滚动 chip -->
  <view class="hot-block">
    <view class="hot-label">常见黑点</view>
    <scroll-view class="hot-scroll" scroll-x enable-flex>
      <view
        wx:for="{{hotBattles}}"
        wx:key="label"
        class="hot-chip"
        data-value="{{item.query}}"
        bindtap="onHotBattleTap"
      >{{item.label}}</view>
    </scroll-view>
  </view>

  <!-- 段位/收藏/历史：底部精简导航 -->
  <view class="nav-row">
    <view
      class="nav-item"
      data-url="/pages/favorites/favorites"
      bindtap="onMenuTap"
    >
      <view class="nav-icon">★</view>
      <text class="nav-text">收藏</text>
    </view>
    <view
      class="nav-item"
      data-url="/pages/history/history"
      bindtap="onMenuTap"
    >
      <view class="nav-icon">↻</view>
      <text class="nav-text">历史</text>
    </view>
    <view
      class="nav-item"
      data-url="/pages/daily/daily"
      bindtap="onMenuTap"
    >
      <view class="nav-icon">·</view>
      <text class="nav-text">每日</text>
    </view>
    <view
      class="nav-item"
      data-url="/pages/leaderboard/leaderboard"
      bindtap="onMenuTap"
    >
      <view class="nav-icon">#</view>
      <text class="nav-text">榜单</text>
    </view>
  </view>

  <view class="footer-note">
    <text class="footer-text">v2.6 · </text>
    <text class="footer-link" data-url="/pages/privacy/privacy" bindtap="onMenuTap">隐私</text>
  </view>

</view>
