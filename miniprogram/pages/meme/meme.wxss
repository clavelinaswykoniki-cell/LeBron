.meme-page {
  min-height: 100vh;
  background: linear-gradient(160deg, #1a0a2e 0%, #2d1245 60%, #3a1860 100%);
  padding: 32rpx 28rpx 80rpx;
  box-sizing: border-box;
}

.page-header {
  margin-bottom: 28rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 900;
  background: linear-gradient(135deg, #ffd700 0%, #ffae00 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  letter-spacing: 2rpx;
}

.subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #b8a3e0;
}

.section {
  margin-bottom: 32rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 26rpx;
  color: #fde68a;
  margin-bottom: 14rpx;
  letter-spacing: 1rpx;
}

.section-head .hint {
  font-size: 20rpx;
  color: rgba(184, 163, 224, 0.65);
  font-weight: 400;
  letter-spacing: 0;
}

.reshuffle-btn {
  font-size: 24rpx;
  color: #ffd700;
  padding: 6rpx 16rpx;
  background: rgba(255, 215, 0, 0.1);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 215, 0, 0.3);
}

/* ----- 横向滚动通用 ----- */
.hscroll {
  width: 100%;
  white-space: nowrap;
}

.hscroll-row {
  display: inline-flex;
  gap: 16rpx;
  padding-bottom: 8rpx;
}

/* ----- 反驳卡候选 ----- */
.candidate-card {
  display: inline-block;
  width: 360rpx;
  padding: 24rpx 20rpx;
  background: rgba(45, 18, 69, 0.6);
  border: 2rpx solid rgba(255, 215, 0, 0.2);
  border-radius: 16rpx;
  vertical-align: top;
  white-space: normal;
  transition: all 0.2s ease;
}

.candidate-card.selected {
  border-color: #ffd700;
  background: rgba(255, 215, 0, 0.15);
  box-shadow: 0 0 24rpx rgba(255, 215, 0, 0.4);
  transform: translateY(-4rpx);
}

.candidate-claim {
  font-size: 24rpx;
  color: #b8a3e0;
  line-height: 1.4;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.candidate-reply {
  font-size: 28rpx;
  color: #fde68a;
  line-height: 1.5;
  font-weight: 600;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ----- 模板候选 ----- */
.template-card {
  display: inline-block;
  width: 180rpx;
  padding: 8rpx;
  background: rgba(45, 18, 69, 0.5);
  border: 2rpx solid rgba(255, 215, 0, 0.2);
  border-radius: 12rpx;
  vertical-align: top;
  text-align: center;
  transition: all 0.2s ease;
}

.template-card.selected {
  border-color: #ffd700;
  background: rgba(255, 215, 0, 0.15);
  box-shadow: 0 0 20rpx rgba(255, 215, 0, 0.5);
  transform: translateY(-4rpx);
}

.template-preview {
  width: 100%;
  height: 280rpx;
  border-radius: 8rpx;
  display: block;
  background: #0f172a;
}

.template-gradient {
  width: 100%;
  height: 280rpx;
  border-radius: 8rpx;
  background: linear-gradient(180deg, #1a0a2e 0%, #2a1145 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.template-gradient-label {
  font-size: 80rpx;
  color: rgba(255, 215, 0, 0.6);
  font-weight: 900;
}

.template-name {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #b8a3e0;
  line-height: 1.2;
}

.template-card.selected .template-name {
  color: #ffd700;
  font-weight: 600;
}

/* ----- 操作区 ----- */
.action-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.action-row button {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 42rpx;
  padding: 0;
  margin: 0;
}

.action-row button::after {
  border: none;
}

.primary-btn {
  background: linear-gradient(135deg, #ffd700 0%, #ffae00 100%);
  color: #1a0a2e;
  box-shadow: 0 8rpx 20rpx rgba(255, 174, 0, 0.4);
}

.primary-btn:active {
  transform: scale(0.96);
}

.primary-btn[disabled] {
  opacity: 0.5;
}

.ghost-btn {
  background: rgba(255, 255, 255, 0.06) !important;
  color: #b8a3e0 !important;
  border: 2rpx solid rgba(184, 163, 224, 0.4) !important;
}

.ghost-btn[disabled] {
  opacity: 0.4;
}

.generated-preview {
  margin-top: 20rpx;
  padding: 16rpx;
  background: rgba(0, 0, 0, 0.3);
  border: 2rpx solid rgba(255, 215, 0, 0.3);
  border-radius: 18rpx;
}

.generated-image {
  width: 100%;
  display: block;
  border-radius: 12rpx;
}

.tip {
  margin-top: 12rpx;
  text-align: center;
  font-size: 22rpx;
  color: #fde68a;
  letter-spacing: 1rpx;
}

.empty-tip {
  margin-top: 80rpx;
  text-align: center;
  color: #b8a3e0;
  font-size: 28rpx;
  opacity: 0.7;
}

/* canvas 必须有 size，但移出视区 */
.hidden-canvas {
  position: fixed;
  top: -10000rpx;
  left: -10000rpx;
  width: 750rpx;
  height: 1334rpx;
}
