/* pages/chat/chat.wxss — 紫金克制风格：白底 + 用户气泡浅紫 + AI 气泡浅金描边 */

page {
  background: #f7f5fb;
  height: 100%;
}

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f7f5fb;
}

/* ========== 顶栏 ========== */
.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #e8e4f0;
}

.topbar-title {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.topbar-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #22c55e;
  box-shadow: 0 0 8rpx rgba(34, 197, 94, 0.6);
}

.topbar-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #170826;
  letter-spacing: 0.5rpx;
}

.topbar-clear {
  font-size: 26rpx;
  color: #7c3aed;
  padding: 8rpx 20rpx;
  border-radius: 28rpx;
  background: #f3eefe;
}

.topbar-clear-disabled {
  color: #c4b8d8;
  background: #f5f3f8;
}

/* ========== 消息流 ========== */
.msg-scroll {
  flex: 1;
  padding: 24rpx 28rpx;
  box-sizing: border-box;
}

.msg-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.msg-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  width: 100%;
}

.msg-row-user {
  justify-content: flex-end;
}

.msg-row-ai {
  justify-content: flex-start;
}

.msg-row-tip {
  justify-content: center;
}

/* AI 头像 */
.ai-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #fde68a, #fbbf24);
  color: #5b3a00;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(251, 191, 36, 0.25);
}

/* ========== 气泡 ========== */
.bubble {
  max-width: 78%;
  padding: 20rpx 26rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  line-height: 1.55;
  word-break: break-word;
  white-space: pre-wrap;
}

/* 用户：浅紫 */
.bubble-user {
  background: linear-gradient(135deg, #ede9fe, #ddd6fe);
  color: #2e1065;
  border-bottom-right-radius: 8rpx;
}

/* AI：白底 + 浅金描边 */
.bubble-ai {
  background: #ffffff;
  color: #170826;
  border: 1.5rpx solid #fde68a;
  border-bottom-left-radius: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(124, 58, 237, 0.06);
}

/* 本地 tip：居中灰胶囊 */
.bubble-tip {
  max-width: 90%;
  background: rgba(124, 58, 237, 0.06);
  color: #6b5b8a;
  font-size: 24rpx;
  padding: 14rpx 24rpx;
  border-radius: 20rpx;
  text-align: center;
  line-height: 1.5;
}

/* 打字气泡：3 个点 */
.bubble-typing {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 24rpx 28rpx;
}

.dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #c4b5fd;
  animation: typing 1.2s infinite ease-in-out;
}

.dot:nth-child(2) {
  animation-delay: 0.15s;
}

.dot:nth-child(3) {
  animation-delay: 0.3s;
}

@keyframes typing {
  0%, 60%, 100% {
    transform: translateY(0);
    opacity: 0.4;
  }
  30% {
    transform: translateY(-6rpx);
    opacity: 1;
  }
}

/* ========== 推荐提问 ========== */
.suggestions {
  margin-top: 28rpx;
  padding: 24rpx 8rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  align-items: center;
}

.suggestions-title {
  width: 100%;
  font-size: 24rpx;
  color: #8b7ca8;
  margin-bottom: 8rpx;
}

.suggest-chip {
  padding: 14rpx 24rpx;
  background: #ffffff;
  border: 1.5rpx solid #e8e0f5;
  border-radius: 28rpx;
  font-size: 26rpx;
  color: #552583;
}

/* 底部 padding 保证最后一条不被输入框遮 */
.msg-bottom-pad {
  height: 32rpx;
}

/* ========== 输入区 ========== */
.composer {
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
  padding: 20rpx 28rpx calc(20rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #e8e4f0;
}

.composer-shell {
  flex: 1;
  background: #f7f5fb;
  border: 1.5rpx solid #e8e0f5;
  border-radius: 20rpx;
  padding: 16rpx 22rpx;
  min-height: 72rpx;
  display: flex;
  align-items: center;
}

.composer-input {
  width: 100%;
  font-size: 30rpx;
  color: #170826;
  line-height: 1.5;
  max-height: 200rpx;
}

.composer-placeholder {
  color: #b5a8cc;
  font-size: 28rpx;
}

.composer-send {
  width: 120rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, #7c3aed, #552583);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(124, 58, 237, 0.3);
  flex-shrink: 0;
}

.composer-send-disabled {
  background: #d6cce8;
  color: #ffffff;
  box-shadow: none;
}
