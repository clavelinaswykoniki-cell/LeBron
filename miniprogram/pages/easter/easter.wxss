.easter-page {
  position: relative;
  min-height: 100vh;
  background: linear-gradient(160deg, #1a0a2e 0%, #2a1145 100%);
  color: #fbbf24;
  padding: 80rpx 40rpx;
  text-align: center;
  overflow: hidden;
}
.watermark {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 600rpx;
  font-weight: 900;
  color: #fbbf24;
  opacity: 0.08;
  pointer-events: none;
}
.hero-text {
  position: relative;
  font-size: 80rpx;
  font-weight: 900;
  letter-spacing: 4rpx;
  margin: 60rpx 0 80rpx;
  color: #fef3c7;
  text-shadow: 0 0 30rpx rgba(251, 191, 36, 0.4);
}
.milestones {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.milestone-card {
  background: rgba(15, 23, 42, 0.55);
  border: 1rpx solid rgba(251, 191, 36, 0.35);
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 30rpx;
  font-weight: 700;
}
.back-btn {
  margin-top: 80rpx;
  background: #fbbf24;
  color: #111827;
  font-weight: 900;
  border-radius: 50rpx;
}
