/* ============================================
 * result.wxss — 拆解结果页 · v2.6 portfolio polish
 *
 * 设计语言（对齐 index.wxss）：
 *   - Apple / Notion 风格：极简、克制、层级清晰
 *   - 浅底 (#fafafa)，白卡 (#ffffff)，墨色字阶
 *   - 紫 (#552583) 仅出现在：query banner、强调 CTA、active 态、关键 accent
 *   - 金 (#FDB927) 仅出现在：23 mark、active 高亮、收藏星
 *   - 大留白：卡间距 28rpx、卡内 padding 32rpx、模块间 22rpx
 *   - 字号阶梯（4 档）：
 *       40rpx 标题  →  30rpx 主回复  →  26rpx 正文  →  22rpx 元数据
 *   - 微交互：所有可点元素都有 transition + :active 反馈
 * ============================================ */

page {
  /* 与首页一致的设计 token */
  --brand-purple: #552583;
  --brand-purple-soft: rgba(85, 37, 131, 0.06);
  --brand-purple-mid: rgba(85, 37, 131, 0.12);
  --brand-purple-line: rgba(85, 37, 131, 0.18);
  --brand-gold: #fdb927;
  --brand-gold-soft: rgba(253, 185, 39, 0.1);
  --brand-gold-mid: rgba(253, 185, 39, 0.18);

  --ink-1: #1a1a1f;
  --ink-2: #4a4a52;
  --ink-3: #8e8e95;
  --ink-4: #c7c7cd;

  --bg-page: #f7f7f8;
  --bg-card: #ffffff;
  --bg-sub: #fafafa;
  --line: rgba(0, 0, 0, 0.06);
  --line-strong: rgba(0, 0, 0, 0.1);

  /* 覆盖 TDesign primary（与首页一致） */
  --td-brand-color: #552583;
  --td-brand-color-1: rgba(85, 37, 131, 0.06);
  --td-brand-color-2: rgba(85, 37, 131, 0.12);

  background: var(--bg-page);
  color: var(--ink-1);
}

.page {
  min-height: 100vh;
  padding: 24rpx 28rpx 64rpx;
  box-sizing: border-box;
}

/* ============================================
 * 顶部 query banner
 *   唯一保留湖人色块的区域 — 视觉锚点
 * ============================================ */
.query-banner {
  position: relative;
  display: flex;
  padding: 36rpx 32rpx 32rpx;
  background:
    radial-gradient(140% 100% at 100% 0%, rgba(253, 185, 39, 0.14) 0%, transparent 55%),
    linear-gradient(135deg, #5a2a8c 0%, #421a6e 100%);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow:
    0 1rpx 0 rgba(255, 255, 255, 0.05) inset,
    0 12rpx 32rpx rgba(85, 37, 131, 0.18);
}

/* 装饰背景：右下大数字 23（更克制 — 降低不透明度） */
.query-banner::after {
  content: "23";
  position: absolute;
  right: -28rpx;
  bottom: -108rpx;
  font-size: 340rpx;
  line-height: 1;
  font-weight: 900;
  color: rgba(253, 185, 39, 0.07);
  letter-spacing: -8rpx;
  pointer-events: none;
  font-family: -apple-system, "SF Pro Display", sans-serif;
}

.banner-line {
  flex: 0 0 4rpx;
  margin-right: 24rpx;
  border-radius: 4rpx;
  background: linear-gradient(180deg, var(--brand-gold) 0%, rgba(253, 185, 39, 0.4) 100%);
}

.banner-body {
  flex: 1;
  min-width: 0;
  position: relative;
  z-index: 1;
}

.banner-eyebrow {
  display: inline-block;
  color: var(--brand-gold);
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  opacity: 0.92;
}

.banner-title {
  margin-top: 12rpx;
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.32;
  word-break: break-word;
  letter-spacing: 0.5rpx;
}

.banner-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 22rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 22rpx;
}

.banner-meta-num {
  color: var(--brand-gold);
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1;
  font-family: -apple-system, "SF Pro Display", sans-serif;
}

.banner-meta-text {
  color: rgba(255, 255, 255, 0.7);
  font-size: 22rpx;
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

.banner-another {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  margin-left: auto;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 1rpx solid rgba(253, 185, 39, 0.32);
  color: var(--brand-gold);
  font-size: 22rpx;
  font-weight: 600;
  transition: all 0.18s ease;
}

.banner-another:active {
  background: rgba(253, 185, 39, 0.18);
  transform: scale(0.96);
}

/* ============================================
 * mood 切换条（页面级 segmented control）
 *   类 iOS segmented control — 滑块感
 * ============================================ */
.mood-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 6rpx;
  margin: 32rpx 0 0;
  padding: 6rpx;
  background: rgba(0, 0, 0, 0.04);
  border-radius: 18rpx;
}

.mood-pill {
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  border-radius: 14rpx;
  background: transparent;
  color: var(--ink-2);
  font-size: 24rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
  transition: background 0.22s ease, color 0.22s ease, box-shadow 0.22s ease, transform 0.18s ease;
}

.mood-pill:active {
  transform: scale(0.97);
}

.mood-pill-active {
  background: #ffffff;
  color: var(--brand-purple);
  font-weight: 700;
  box-shadow:
    0 1rpx 2rpx rgba(0, 0, 0, 0.04),
    0 4rpx 12rpx rgba(85, 37, 131, 0.1);
}

/* ============================================
 * 卡片
 * ============================================ */
.cards {
  margin-top: 28rpx;
}

.card {
  position: relative;
  margin-bottom: 24rpx;
  padding: 32rpx;
  border-radius: 24rpx;
  background: var(--bg-card);
  box-shadow:
    0 1rpx 0 var(--line),
    0 8rpx 32rpx rgba(0, 0, 0, 0.04);
}

/* ----- 卡片顶部 meta ----- */
.card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.card-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
  flex: 1;
  min-width: 0;
}

.category-tag {
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  background: var(--brand-purple-soft);
  color: var(--brand-purple);
  font-size: 21rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.alias-tag {
  color: var(--ink-3);
  font-size: 21rpx;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 360rpx;
}

.fav-star {
  flex: 0 0 56rpx;
  width: 56rpx;
  height: 56rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: transparent;
  color: var(--ink-4);
  font-size: 38rpx;
  line-height: 1;
  transition: background 0.18s ease, color 0.18s ease, transform 0.18s ease;
}

.fav-star:active {
  transform: scale(0.88);
  background: rgba(0, 0, 0, 0.04);
}

.fav-star-on {
  color: var(--brand-gold);
  background: var(--brand-gold-soft);
}

.fav-star-on:active {
  background: var(--brand-gold-mid);
}

/* ----- claim 框（对方原话） ----- */
.claim-box {
  margin-top: 24rpx;
  padding: 22rpx 24rpx;
  border-radius: 16rpx;
  background: var(--bg-sub);
  border-left: 4rpx solid rgba(220, 38, 38, 0.5);
}

.claim-label {
  color: var(--ink-3);
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  margin-bottom: 8rpx;
}

.claim-text {
  color: var(--ink-1);
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1.5;
}

/* ----- "先回这句" 高亮（核心区域） ----- */
.hit-box {
  margin-top: 22rpx;
  padding: 28rpx;
  border-radius: 18rpx;
  background:
    linear-gradient(135deg, rgba(85, 37, 131, 0.04) 0%, rgba(253, 185, 39, 0.06) 100%);
  border: 1rpx solid var(--brand-purple-line);
  position: relative;
}

.hit-tag {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  color: var(--brand-purple);
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.hit-tag-dot {
  display: inline-block;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--brand-gold);
  box-shadow: 0 0 0 3rpx rgba(253, 185, 39, 0.18);
}

.hit-text {
  margin-top: 14rpx;
  color: var(--ink-1);
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.55;
  letter-spacing: 0.3rpx;
  /* fade-in 切换动效 */
  animation: hitTextFade 0.32s ease;
}

@keyframes hitTextFade {
  from { opacity: 0; transform: translateY(4rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

.hit-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 20rpx;
}

.hit-copy-btn {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: var(--brand-purple);
  color: #ffffff;
  font-size: 23rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
  transition: transform 0.15s ease, background 0.15s ease, box-shadow 0.15s ease;
  box-shadow: 0 2rpx 8rpx rgba(85, 37, 131, 0.18);
}

.hit-copy-btn:active {
  transform: scale(0.96);
  background: #4a1f74;
  box-shadow: 0 1rpx 4rpx rgba(85, 37, 131, 0.16);
}

/* 让 t-icon 在按钮里跟着白色（覆盖 inline color） */
.hit-copy-btn t-icon {
  --td-icon-color: #ffffff;
}

/* ----- 4 mood 复制按钮组（卡内细化版） ----- */
.copy-strip {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
  margin-top: 22rpx;
}

.copy-strip-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  padding: 14rpx 4rpx;
  border-radius: 14rpx;
  background: var(--bg-sub);
  border: 1rpx solid transparent;
  transition: all 0.18s ease;
}

.copy-strip-btn:active {
  transform: scale(0.96);
  background: var(--brand-purple-soft);
}

.copy-strip-btn-active {
  background: var(--brand-purple-soft);
  border-color: var(--brand-purple-line);
}

.copy-strip-name {
  font-size: 23rpx;
  font-weight: 600;
  color: var(--ink-1);
  letter-spacing: 1rpx;
}

.copy-strip-btn-active .copy-strip-name {
  color: var(--brand-purple);
  font-weight: 700;
}

.copy-strip-hint {
  font-size: 18rpx;
  color: var(--ink-3);
  letter-spacing: 1rpx;
  font-weight: 500;
}

.copy-strip-btn-active .copy-strip-hint {
  color: var(--brand-purple);
  opacity: 0.7;
}

/* ----- 折叠开关 ----- */
.expand-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-top: 22rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: transparent;
  border: 1rpx solid var(--line);
  color: var(--ink-2);
  font-size: 23rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
  transition: all 0.18s ease;
}

.expand-toggle:active {
  background: var(--brand-purple-soft);
  border-color: var(--brand-purple-line);
  color: var(--brand-purple);
}

.expand-arrow {
  color: var(--ink-3);
  font-size: 28rpx;
  line-height: 1;
  margin-top: -4rpx;
  transition: transform 0.24s ease;
}

.expand-toggle-open .expand-arrow {
  transform: rotate(180deg);
}

/* ----- 折叠展开区 ----- */
.expand-panel {
  margin-top: 18rpx;
  padding: 26rpx;
  border-radius: 16rpx;
  background: var(--bg-sub);
  animation: expandFade 0.28s ease;
}

@keyframes expandFade {
  from { opacity: 0; transform: translateY(-6rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

.ext-section {
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--line);
}

.ext-section:last-of-type {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.ext-title {
  color: var(--ink-3);
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  margin-bottom: 10rpx;
}

.ext-title.gold {
  color: #a07410;  /* 金色文字版，浅底上更克制 */
}

.ext-text {
  color: var(--ink-1);
  font-size: 26rpx;
  line-height: 1.7;
}

.ext-text-strong {
  color: var(--ink-1);
  font-weight: 700;
  font-size: 28rpx;
}

.ext-text.muted {
  color: var(--ink-3);
  font-size: 24rpx;
}

/* ----- facts ----- */
.facts-block {
  margin-top: 20rpx;
  padding: 18rpx 20rpx;
  border-radius: 12rpx;
  background: var(--brand-gold-soft);
  border-left: 3rpx solid var(--brand-gold);
}

.facts-title {
  color: #a07410;
  font-size: 20rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.fact-row {
  color: var(--ink-1);
  font-size: 23rpx;
  line-height: 1.7;
}

/* ----- tags ----- */
.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 22rpx;
}

.tag-chip {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: transparent;
  border: 1rpx solid var(--line);
  color: var(--ink-3);
  font-size: 21rpx;
  font-weight: 500;
}

/* ----- 卡片底部 actions ----- */
.card-foot {
  display: flex;
  gap: 12rpx;
  margin-top: 26rpx;
}

.foot-btn {
  flex: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  border-radius: 16rpx;
  font-size: 25rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
  transition: transform 0.15s ease, background 0.15s ease, box-shadow 0.15s ease;
}

.foot-btn:active {
  transform: scale(0.97);
}

.foot-btn-gold {
  background: var(--brand-purple);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(85, 37, 131, 0.18);
}

.foot-btn-gold:active {
  background: #4a1f74;
  box-shadow: 0 2rpx 6rpx rgba(85, 37, 131, 0.16);
}

.foot-btn-ghost {
  background: transparent;
  border: 1rpx solid var(--line-strong);
  color: var(--ink-1);
}

.foot-btn-ghost:active {
  background: var(--brand-purple-soft);
  border-color: var(--brand-purple-line);
  color: var(--brand-purple);
}

.foot-btn-disabled {
  opacity: 0.5;
}

.card-foot-hint {
  margin-top: 14rpx;
  text-align: center;
  color: var(--ink-4);
  font-size: 20rpx;
  letter-spacing: 1rpx;
}

/* ============================================
 * 空状态
 * ============================================ */
.empty {
  margin-top: 80rpx;
  padding: 80rpx 32rpx;
  text-align: center;
  border-radius: 24rpx;
  background: var(--bg-card);
}

.empty-emoji {
  font-size: 80rpx;
  opacity: 0.8;
}

.empty-title {
  margin-top: 18rpx;
  color: var(--ink-1);
  font-size: 30rpx;
  font-weight: 700;
}

.empty-sub {
  margin-top: 10rpx;
  color: var(--ink-3);
  font-size: 24rpx;
}

/* ============================================
 * 底部操作条
 * ============================================ */
.bottom-bar {
  display: flex;
  justify-content: center;
  margin-top: 16rpx;
  margin-bottom: 12rpx;
}

.bottom-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 24rpx 36rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
  transition: transform 0.15s ease, background 0.15s ease, box-shadow 0.15s ease;
}

.bottom-btn-primary {
  background: var(--brand-purple);
  color: #ffffff;
  box-shadow: 0 6rpx 20rpx rgba(85, 37, 131, 0.22);
}

.bottom-btn-primary:active {
  transform: scale(0.97);
  background: #4a1f74;
}

.bottom-btn-primary t-icon {
  --td-icon-color: #ffffff;
}

.page-footer {
  margin-top: 32rpx;
  text-align: center;
  color: var(--ink-4);
  font-size: 20rpx;
  letter-spacing: 1rpx;
}

/* ============================================
 * 分享画布（隐藏在屏幕外）
 * ============================================ */
.share-canvas {
  position: fixed;
  top: -3000rpx;
  left: -3000rpx;
  pointer-events: none;
}
