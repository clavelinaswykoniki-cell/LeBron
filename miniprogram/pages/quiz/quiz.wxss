page {
  background: #1a0a2e;
  min-height: 100vh;
  color: #f5e6c8;
}

.container {
  padding: 48rpx 32rpx;
  box-sizing: border-box;
}

/* Progress */
.progress {
  margin-bottom: 56rpx;
}

.progress-text {
  font-size: 28rpx;
  color: #d4af37;
  text-align: center;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.progress-bar {
  width: 100%;
  height: 12rpx;
  background: rgba(212, 175, 55, 0.15);
  border: 2rpx solid #d4af37;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #d4af37, #f5d76e);
  transition: width 0.3s ease;
}

/* Question */
.question {
  font-size: 36rpx;
  text-align: center;
  line-height: 1.6;
  margin: 64rpx 0;
  color: #f5e6c8;
  padding: 0 16rpx;
}

/* Options */
.options {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-top: 48rpx;
}

.option-btn {
  width: 100%;
  background: #1a0a2e;
  color: #f5e6c8;
  border: 2rpx solid #d4af37;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  font-size: 30rpx;
  line-height: 1.5;
  text-align: center;
  box-sizing: border-box;
}

.option-btn::after {
  border: none;
}

.option-btn:active {
  background: #2a1a4a;
  color: #d4af37;
}

/* Result */
.result {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 24rpx;
}

.result-title {
  font-size: 64rpx;
  color: #d4af37;
  font-weight: bold;
  margin-bottom: 32rpx;
  text-align: center;
  letter-spacing: 4rpx;
}

.result-desc {
  font-size: 30rpx;
  color: #f5e6c8;
  text-align: center;
  line-height: 1.7;
  margin-bottom: 64rpx;
  padding: 0 16rpx;
}

.action-btn {
  width: 100%;
  background: #1a0a2e;
  color: #f5e6c8;
  border: 2rpx solid #d4af37;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 30rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.action-btn.primary {
  background: #d4af37;
  color: #1a0a2e;
  font-weight: bold;
}

.action-btn::after {
  border: none;
}

.action-btn:active {
  opacity: 0.8;
}
