<view class="page">
  <view class="header">
    <view class="date">{{dateLabel}}</view>
    <view class="title">今日黑点</view>
    <view class="subtitle">每天一张，按日期固定</view>
  </view>

  <view class="checkin-card">
    <view class="checkin-row">
      <view class="checkin-col">
        <view class="streak-num">{{checkin.streak || 0}}</view>
        <view class="streak-label">连续签到</view>
      </view>
      <view class="checkin-divider"></view>
      <view class="checkin-col">
        <view class="streak-num">{{checkin.totalDays || 0}}</view>
        <view class="streak-label">累计天数</view>
      </view>
    </view>
    <view class="checkin-tip" wx:if="{{checkin.todaySigned}}">今日已签到</view>
  </view>

  <block wx:if="{{card}}">
    <view class="daily-card">
      <view class="tag">{{card.category}}</view>

      <view class="block">
        <view class="block-label">黑粉话术</view>
        <view class="claim">{{card.claim}}</view>
      </view>

      <view class="divider"></view>

      <view class="block">
        <view class="block-label">一句反击</view>
        <view class="short-reply">{{card.short_reply}}</view>
      </view>

      <view class="copy-btn" bindtap="copyShort">复制反击</view>
    </view>
  </block>

  <view class="empty" wx:else>
    <view>今日卡片加载失败</view>
    <view class="empty-sub">请稍后重试</view>
  </view>

  <view class="actions">
    <view class="btn btn-primary" bindtap="goPK">去 PK</view>
    <view class="btn btn-ghost" bindtap="goLeaderboard">看排行</view>
  </view>

  <view class="back" bindtap="goBack">返回</view>
</view>
