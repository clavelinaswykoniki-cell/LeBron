/* 每日一战 · 紫金主题 */

page {
  background: #1a0a2e;
}

.page {
  min-height: 100vh;
  padding: 32rpx 32rpx 64rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #1a0a2e 0%, #2a0f4e 100%);
  color: #f5e9d3;
}

/* 顶部 */
.header {
  margin-bottom: 28rpx;
}
.date {
  font-size: 26rpx;
  color: #c8b6e8;
  letter-spacing: 1rpx;
}
.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #fbbf24;
  margin-top: 8rpx;
}
.subtitle {
  font-size: 24rpx;
  color: #a78bd0;
  margin-top: 6rpx;
}

/* 签到卡 */
.checkin-card {
  margin-top: 12rpx;
  padding: 28rpx 24rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #2d1456 0%, #4a1f7a 100%);
  border: 2rpx solid #fbbf24;
  box-shadow: 0 4rpx 18rpx rgba(251, 191, 36, 0.18);
}
.checkin-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
}
.checkin-col {
  flex: 1;
  text-align: center;
}
.checkin-divider {
  width: 2rpx;
  height: 80rpx;
  background: rgba(251, 191, 36, 0.4);
}
.streak-num {
  font-size: 56rpx;
  font-weight: 800;
  color: #fbbf24;
  line-height: 1.1;
}
.streak-label {
  font-size: 24rpx;
  color: #d8c4f0;
  margin-top: 8rpx;
}
.checkin-tip {
  margin-top: 16rpx;
  text-align: center;
  font-size: 22rpx;
  color: #fbbf24;
  opacity: 0.85;
}

/* 主卡 */
.daily-card {
  margin-top: 32rpx;
  padding: 32rpx;
  border-radius: 24rpx;
  background: linear-gradient(160deg, #3a1668 0%, #1f0c40 100%);
  border: 1rpx solid rgba(251, 191, 36, 0.3);
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.35);
}
.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(251, 191, 36, 0.18);
  color: #fbbf24;
  font-size: 24rpx;
  margin-bottom: 24rpx;
}
.block {
  margin-bottom: 20rpx;
}
.block-label {
  font-size: 22rpx;
  color: #a78bd0;
  margin-bottom: 10rpx;
  letter-spacing: 2rpx;
}
.claim {
  font-size: 32rpx;
  line-height: 1.55;
  color: #ece2ff;
}
.short-reply {
  font-size: 30rpx;
  line-height: 1.6;
  color: #fbbf24;
  font-weight: 700;
}
.divider {
  height: 1rpx;
  background: rgba(251, 191, 36, 0.2);
  margin: 24rpx 0;
}

/* 复制按钮 */
.copy-btn {
  margin-top: 28rpx;
  text-align: center;
  padding: 22rpx 0;
  border-radius: 16rpx;
  background: #fbbf24;
  color: #1a0a2e;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 4rpx 12rpx rgba(251, 191, 36, 0.35);
}
.copy-btn:active {
  opacity: 0.85;
}

/* 空态 */
.empty {
  margin-top: 60rpx;
  text-align: center;
  color: #c8b6e8;
  font-size: 28rpx;
}
.empty-sub {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #8b6fb8;
}

/* 底部按钮 */
.actions {
  margin-top: 40rpx;
  display: flex;
  gap: 20rpx;
}
.btn {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
}
.btn-primary {
  background: linear-gradient(135deg, #fbbf24, #f59e0b);
  color: #1a0a2e;
  box-shadow: 0 4rpx 14rpx rgba(251, 191, 36, 0.3);
}
.btn-primary:active { opacity: 0.85; }
.btn-ghost {
  background: transparent;
  border: 2rpx solid #fbbf24;
  color: #fbbf24;
}
.btn-ghost:active { background: rgba(251, 191, 36, 0.1); }

/* 返回 */
.back {
  margin-top: 32rpx;
  text-align: center;
  font-size: 26rpx;
  color: #a78bd0;
}
.back:active { color: #fbbf24; }
