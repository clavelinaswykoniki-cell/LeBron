.pk-page {
  min-height: 100vh;
  background: #1a0a2e;
  padding: 32rpx 32rpx 80rpx 32rpx;
  box-sizing: border-box;
  color: #fbbf24;
}

.quiz-wrap {
  display: flex;
  flex-direction: column;
}

.progress-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.progress-text {
  font-size: 26rpx;
  color: #fbbf24;
  letter-spacing: 1rpx;
}

.progress-bar {
  width: 100%;
  height: 6rpx;
  background: rgba(251, 191, 36, 0.2);
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 32rpx;
}

.progress-fill {
  height: 100%;
  background: #fbbf24;
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.card {
  background: #2d1b4e;
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 32rpx;
}

.prompt {
  font-size: 24rpx;
  color: rgba(251, 191, 36, 0.7);
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
}

.claim {
  font-size: 36rpx;
  color: #ffffff;
  text-align: center;
  padding: 24rpx;
  background: #2d1b4e;
  border-radius: 14rpx;
  line-height: 1.5;
  font-weight: 500;
}

.category-tag {
  display: inline-block;
  margin-top: 20rpx;
  padding: 6rpx 18rpx;
  font-size: 22rpx;
  color: #fbbf24;
  border: 1rpx solid #fbbf24;
  border-radius: 20rpx;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-bottom: 40rpx;
}

.option-btn {
  display: block;
  width: 100%;
  height: 110rpx;
  line-height: 110rpx;
  border-radius: 14rpx;
  border: 1rpx solid #fbbf24;
  background: transparent;
  color: #fbbf24;
  font-size: 28rpx;
  text-align: center;
  padding: 0 24rpx;
  box-sizing: border-box;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.option-btn.selected {
  background: #fbbf24;
  color: #170826;
  font-weight: 600;
}

.confirm-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 14rpx;
  background: #fbbf24;
  color: #170826;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.confirm-btn[disabled] {
  background: rgba(251, 191, 36, 0.3);
  color: rgba(23, 8, 38, 0.5);
}

.result-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 80rpx;
}

.result-score {
  font-size: 120rpx;
  color: #fbbf24;
  font-weight: 700;
  text-align: center;
  line-height: 1.1;
}

.result-sub {
  font-size: 32rpx;
  color: #ffffff;
  margin-top: 16rpx;
}

.result-rank {
  font-size: 28rpx;
  color: #fbbf24;
  margin-top: 20rpx;
  padding: 10rpx 24rpx;
  border: 1rpx solid #fbbf24;
  border-radius: 24rpx;
}

.result-stats {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  padding: 24rpx;
  margin-top: 32rpx;
  text-align: center;
}

.result-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 24rpx;
}

.action-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 14rpx;
  background: transparent;
  border: 1rpx solid #fbbf24;
  color: #fbbf24;
  font-size: 28rpx;
}

.action-btn.primary {
  background: #fbbf24;
  color: #170826;
  font-weight: 600;
  border: none;
}
