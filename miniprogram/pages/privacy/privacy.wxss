.privacy-page {
  min-height: 100vh;
  background: #1a0a2e;
  padding: 40rpx 32rpx 80rpx;
  box-sizing: border-box;
}

.title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #f5c518;
  margin-bottom: 12rpx;
}

.updated {
  display: block;
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 36rpx;
}

.section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #f5c518;
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.section-body {
  font-size: 26rpx;
  color: #ffffff;
  line-height: 1.6;
}

button {
  margin-top: 48rpx;
  background: #f5c518;
  color: #1a0a2e;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 12rpx;
}
